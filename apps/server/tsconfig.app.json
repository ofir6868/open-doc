{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@open-doc/shared": ["../../libs/shared/src/index.ts"]
    },
    "rootDir": "src",
    "outDir": "../../dist/apps/server",
    "types": ["node", "multer"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2021"],
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "isolatedModules": false,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [],
  "references": [
    {
      "path": "../../libs/shared/tsconfig.lib.json"
    }
  ]
}
